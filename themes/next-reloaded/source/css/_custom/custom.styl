// APlayer样式
.aplayer {
  box-shadow: 0 2px 2px 0 rgba(0,0,0,0.12), 0 3px 1px -2px rgba(0,0,0,0.06), 0 1px 5px 0 rgba(0,0,0,0.12), 0 -1px 0.5px 0 rgba(0,0,0,0.09) !important;
  border-radius: 0 !important;
}

.aplayer-played {
  background: rgb(221, 75, 57) none repeat scroll 0% 0% !important;
}

.aplayer-pic {
  background-color: #b9514d !important;
}

.aplayer-thumb,
.aplayer-list-cur {
  background-color: #dd4b39 !important;
}

// 侧栏底色透明
// .sidebar { background: transparent; }

// 处理连续图片下的br
a.fancybox + br {
  height: 0;
  font-size: 0;
  display: none;
}

// 自定义类名
.no-border {
    border: none !important;
}

.ta-center {
    text-align: center;
}

// 居中块引用
.cq-author {
  text-align: right !important;
  font-style: italic;
  padding-right: 4em;
  color: #999;
}

// LOGO
.site-title {
  font-family: "Uncial Antiqua","Lato","PingFang SC","Microsoft YaHei",sans-serif;
  font-weight: 700;
}

.site-author-name {
  font-family: "Cinzel";
}

// footer 字体
.footer-inner,
.copyright span {
  font-family: "Cinzel","Constantia";
}


// 取消标题的下边框，需要时手动用hr代替
.post-body {
  h1, h2, h3, h4, h5, h6 {
    // border-bottom: 0px solid #eee;
    +hr {
      margin-top: 12px;
      margin-bottom: 30px;
    }
  }
}

// 自定义背景图
body {
  background-image: url(../images/main-bg-2.png);
}

