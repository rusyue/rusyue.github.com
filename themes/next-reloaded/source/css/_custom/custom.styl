// 单行代码样式
code {
  // background: rgba(27, 31, 35, 0.1);
  background: rgba(159, 53, 58, 0.08);
  color: #CB4042;
  margin-left: 2px;
  margin-right: 2px;
}

.post-body .label {
  &.default,
  &.primary,
  &.success,
  &.warning,
  &.danger,
  &.info {
    padding: 2px 4px;
    border-radius: 3px;
  }
}